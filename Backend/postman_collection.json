{
  "info": {
    "name": "Swagatam Kashi Backend API",
    "description": "Hotel & Tour Booking Platform - Complete API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "customerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "hotelOwnerToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Raj Kumar\",\n  \"email\": \"raj@customer.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"role\": \"customer\"\n}"
            }
          }
        },
        {
          "name": "Register Hotel Owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Suresh Patel\",\n  \"email\": \"suresh@hotel.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543211\",\n  \"role\": \"hotel_owner\",\n  \"businessName\": \"Kashi Grand Hotel\",\n  \"businessLicense\": \"HOT-LIC-2025-001\"\n}"
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/users/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Admin Sharma\",\n  \"email\": \"admin@swagatam.com\",\n  \"password\": \"admin@123\",\n  \"phone\": \"9876543212\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"raj@customer.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              }
            ],
            "url": "{{baseUrl}}/users/me"
          }
        }
      ]
    },
    {
      "name": "Hotels",
      "item": [
        {
          "name": "Get All Hotels",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/hotels?city=Varanasi"
          }
        },
        {
          "name": "Create Hotel",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{hotelOwnerToken}}"
              }
            ],
            "url": "{{baseUrl}}/hotels",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Kashi Palace Hotel\",\n  \"description\": \"Luxury 5-star hotel\",\n  \"address\": {\n    \"street\": \"Dashashwamedh Ghat\",\n    \"city\": \"Varanasi\",\n    \"state\": \"UP\",\n    \"pincode\": \"221001\"\n  },\n  \"location\": {\n    \"coordinates\": [82.9739, 25.3176]\n  },\n  \"roomTypes\": [\n    {\n      \"type\": \"Deluxe\",\n      \"price\": 3500,\n      \"capacity\": 2,\n      \"available\": 10\n    }\n  ],\n  \"amenities\": [\"WiFi\", \"Pool\"]\n}"
            }
          }
        }
      ]
    }
  ]
}
